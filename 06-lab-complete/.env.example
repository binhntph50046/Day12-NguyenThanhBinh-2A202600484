# ============================================================
# Environment Variables Template
# 
# Hướng dẫn:
# 1. Copy file này thành .env.local
# 2. Điền giá trị thật
# 3. ❌ KHÔNG commit .env.local lên Git
# 
# Tại sao dùng Environment Variables? (12-Factor App)
# - Tách config khỏi code
# - Dễ deploy lên nhiều môi trường (dev/staging/prod)
# - Bảo mật: Secrets không nằm trong code
# ============================================================

# ─────────────────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true

# ─────────────────────────────────────────────────────────
# Application Info
# ─────────────────────────────────────────────────────────
APP_NAME=AI Agent
APP_VERSION=1.0.0

# ─────────────────────────────────────────────────────────
# LLM Configuration
# ─────────────────────────────────────────────────────────
# Để trống = dùng Mock LLM (không tốn tiền)
# Điền API key = dùng OpenAI thật
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────
# Security — ⚠️ BẮT BUỘC thay trong production
# ─────────────────────────────────────────────────────────
# Generate strong key: openssl rand -hex 32
AGENT_API_KEY=dev-key-change-me-in-production
JWT_SECRET=dev-jwt-secret-change-in-production

# ─────────────────────────────────────────────────────────
# Rate Limiting & Budget Protection
# ─────────────────────────────────────────────────────────
# Rate limit: 5 requests/phút (đủ cho demo, tránh abuse)
RATE_LIMIT_PER_MINUTE=5
DAILY_BUDGET_USD=5.0

# ─────────────────────────────────────────────────────────
# Storage — Redis for rate limiting & sessions
# ─────────────────────────────────────────────────────────
# Local: redis://localhost:6379/0
# Railway: Tự động set bởi Railway
# Render: Tự động set bởi Render
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────────────────
# CORS — Allowed origins
# ─────────────────────────────────────────────────────────
# Development: http://localhost:3000
# Production: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
